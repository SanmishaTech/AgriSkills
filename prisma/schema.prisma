generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "mysql"
}

model User {
  id                 String                   @id @default(uuid())
  phone              String?                  @unique
  email              String?                  @unique
  password           String
  name               String?
  role               String                   @default("user")
  profilePhoto       String?
  lastUrl            String?
  createdAt          DateTime                 @default(now())
  updatedAt          DateTime                 @updatedAt
  certificates       Certificate[]
  courseCompletions  CourseCompletion[]
  quizAttempts       QuizAttempt[]
  questionSelections TopicQuestionSelection[]

  @@map("user")
}

model Topic {
  id          String          @id @default(uuid())
  title       String
  description String?
  thumbnail   String?
  isActive    Boolean         @default(true)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  subtopics   Subtopic[]
  demo        TopicDemo?
  questions   TopicQuestion[]

  @@map("topic")
}

model Subtopic {
  id          String   @id @default(uuid())
  title       String
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  topicId     String
  courses     Course[]
  topic       Topic    @relation(fields: [topicId], references: [id], onDelete: Cascade)

  @@index([topicId], map: "subtopic_topicId_fkey")
  @@map("subtopic")
}

model Organization {
  id           String   @id @default(uuid())
  name         String
  description  String?
  htmlTemplate String?  @db.LongText
  isDefault    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  courses      Course[]

  @@map("organization")
}

model Course {
  id             String             @id @default(uuid())
  title          String
  description    String?
  thumbnail      String?
  duration       Int?
  level          String?
  isActive       Boolean            @default(true)
  isPublic       Boolean            @default(true)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  subtopicId     String
  organizationId String?
  chapters       Chapter[]
  organization   Organization?      @relation(fields: [organizationId], references: [id])
  subtopic       Subtopic           @relation(fields: [subtopicId], references: [id], onDelete: Cascade)
  completions    CourseCompletion[]

  @@index([organizationId], map: "course_organizationId_fkey")
  @@index([subtopicId], map: "course_subtopicId_fkey")
  @@map("course")
}

model Chapter {
  id          String      @id @default(uuid())
  title       String
  description String?
  content     String      @db.LongText
  youtubeUrl  String?
  orderIndex  Int         @default(0)
  isActive    Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  courseId    String
  course      Course      @relation(fields: [courseId], references: [id], onDelete: Cascade)
  demoVideos  DemoVideo[]
  quiz        Quiz?
  sections    Section[]

  @@index([courseId], map: "chapter_courseId_fkey")
  @@map("chapter")
}

model DemoVideo {
  id           String   @id @default(uuid())
  title        String
  description  String?
  videoUrl     String
  duration     Int?
  thumbnailUrl String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  chapterId    String
  chapter      Chapter  @relation(fields: [chapterId], references: [id], onDelete: Cascade)

  @@index([chapterId], map: "demovideo_chapterId_fkey")
  @@map("demovideo")
}

model Section {
  id         String   @id @default(uuid())
  title      String
  content    String   @db.LongText
  orderIndex Int
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  chapterId  String
  chapter    Chapter  @relation(fields: [chapterId], references: [id], onDelete: Cascade)

  @@index([chapterId], map: "section_chapterId_fkey")
  @@map("section")
}

model TopicDemo {
  id        String   @id @default(uuid())
  topicId   String   @unique
  demoUrls  String   @db.LongText
  content   String   @db.LongText
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  topic     Topic    @relation(fields: [topicId], references: [id], onDelete: Cascade)

  @@map("topicdemo")
}

model TopicQuestion {
  id         String                   @id @default(uuid())
  topicId    String
  question   String
  isActive   Boolean                  @default(true)
  orderIndex Int                      @default(0)
  createdAt  DateTime                 @default(now())
  updatedAt  DateTime                 @updatedAt
  topic      Topic                    @relation(fields: [topicId], references: [id], onDelete: Cascade)
  selections TopicQuestionSelection[]

  @@index([topicId], map: "topicquestion_topicId_fkey")
  @@map("topicquestion")
}

model TopicQuestionSelection {
  id         String        @id @default(uuid())
  userId     String
  questionId String
  topicId    String
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  question   TopicQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, questionId])
  @@index([userId])
  @@index([topicId])
  @@index([questionId], map: "topicquestionselection_questionId_fkey")
  @@map("topicquestionselection")
}

model YouTubeShort {
  id           String   @id @default(uuid())
  title        String
  description  String?
  url          String   @unique
  videoId      String
  thumbnailUrl String
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("youtubeshort")
}

model Quiz {
  id           String        @id @default(uuid())
  title        String
  description  String?
  isActive     Boolean       @default(true)
  passingScore Int           @default(50)
  timeLimit    Int?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  chapterId    String        @unique
  questions    Question[]
  chapter      Chapter       @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  attempts     QuizAttempt[]

  @@map("quiz")
}

model Question {
  id         String         @id @default(uuid())
  text       String
  type       String         @default("multiple_choice")
  points     Int            @default(1)
  orderIndex Int            @default(0)
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
  quizId     String
  answers    Answer[]
  quiz       Quiz           @relation(fields: [quizId], references: [id], onDelete: Cascade)
  responses  QuizResponse[]

  @@index([quizId], map: "question_quizId_fkey")
  @@map("question")
}

model Answer {
  id         String   @id @default(uuid())
  text       String
  isCorrect  Boolean  @default(false)
  orderIndex Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  questionId String
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([questionId], map: "answer_questionId_fkey")
  @@map("answer")
}

model QuizAttempt {
  id               String            @id @default(uuid())
  score            Float
  totalPoints      Int
  maxPoints        Int
  isPassed         Boolean
  timeSpent        Int?
  startedAt        DateTime          @default(now())
  completedAt      DateTime?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  userId           String
  quizId           String
  certificate      Certificate?
  courseCompletion CourseCompletion?
  quiz             Quiz              @relation(fields: [quizId], references: [id], onDelete: Cascade)
  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  responses        QuizResponse[]

  @@index([quizId], map: "quizattempt_quizId_fkey")
  @@index([userId], map: "quizattempt_userId_fkey")
  @@map("quizattempt")
}

model QuizResponse {
  id           String      @id @default(uuid())
  selectedText String?
  isCorrect    Boolean
  pointsEarned Int
  createdAt    DateTime    @default(now())
  attemptId    String
  questionId   String
  answerId     String?
  attempt      QuizAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  question     Question    @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([attemptId], map: "quizresponse_attemptId_fkey")
  @@index([questionId], map: "quizresponse_questionId_fkey")
  @@map("quizresponse")
}

model Certificate {
  id              String      @id @default(uuid())
  certificateUrl  String?
  certificateData String?     @db.LongText
  issuedAt        DateTime    @default(now())
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  userId          String
  attemptId       String      @unique
  attempt         QuizAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  user            User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "certificate_userId_fkey")
  @@map("certificate")
}

model CourseCompletion {
  id            String       @id @default(cuid())
  userId        String
  courseId      String
  completedAt   DateTime     @default(now())
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  quizAttemptId String?      @unique
  course        Course       @relation(fields: [courseId], references: [id], onDelete: Cascade)
  quizAttempt   QuizAttempt? @relation(fields: [quizAttemptId], references: [id])
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@index([userId])
  @@index([courseId])
  @@index([completedAt])
  @@map("coursecompletion")
}

model SupportTicket {
  id        String   @id @default(uuid())
  name      String
  email     String
  subject   String
  message   String   @db.LongText
  status    String   @default("pending")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
  @@index([status])
  @@index([createdAt])
  @@map("supportticket")
}

model AppConfig {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String   @db.LongText
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("app_config")
}
